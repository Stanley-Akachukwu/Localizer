<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Lacalizer.Mobile.Views.ReelPage"
             Title="ReelPage"
            xmlns:models="clr-namespace:Lacalizer.Mobile.Models"
            xmlns:viewModels="clr-namespace:Lacalizer.Mobile.ViewModels"
            xmlns:media="clr-namespace:Lacalizer.Mobile.CustomControls.Media"
            x:Name="Reels"
            x:DataType="viewModels:ReelViewModel"
            Shell.NavBarIsVisible="False">

    <Grid>

        <CollectionView
         HeightRequest="{Binding Height, Source={x:Reference Reels}}"
         HorizontalOptions="Fill"
         VerticalOptions="Center"
         ItemsSource="{Binding Videos}"
         Scrolled="ItemsView_OnScrolled">

            <CollectionView.ItemsLayout>
                <LinearItemsLayout
                 Orientation="Vertical"
                 SnapPointsType="MandatorySingle"
                 SnapPointsAlignment="Center" />
            </CollectionView.ItemsLayout>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ReelVideoModel">
                    <Grid
                     HeightRequest="{Binding Height, Source={x:Reference Reels}}"
                     BackgroundColor="{Binding BackgroundColor}"
                     HorizontalOptions="Fill">

                        <!-- Video Player -->
                        <media:ExtendedMediaElement
                         Aspect="AspectFill"
                         Source="{Binding VideoUri}"
                         ShouldAutoPlay="False"
                         ShouldLoopPlayback="True"
                         ShouldShowPlaybackControls="False"
                         IsPlaying="{Binding IsPlaying}" />

                        <!-- Top Caption & Localize Button -->
                        <StackLayout
                         HorizontalOptions="Center"
                         VerticalOptions="Start"
                         Margin="0,40,0,0"
                         Spacing="5">

                            <Label 
                            x:Name="lblTopic"
                             Text="{Binding Topic}"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             TextColor="White"
                             FontSize="16"
                             FontAttributes="Bold"
                             Padding="20,10" />

                            <ImageButton
                            Source="localize"
                            HeightRequest="36"
                            WidthRequest="36"
                            BackgroundColor="#66000000"
                            CornerRadius="18"
                            Padding="8"
                             Command="{Binding Source={x:Reference Reels}, Path=BindingContext.RecordVideoCommand}" />

                        </StackLayout>

                        <!-- Right Action Buttons -->
                        <StackLayout
                      Orientation="Vertical"
                      Spacing="25"
                      HorizontalOptions="End"
                      VerticalOptions="End"
                      Margin="0,0,20,40">

                          
                            <!-- PARTICIPANTS -->
                            <StackLayout Spacing="4">
                                <ImageButton
                                    Source="participations"
                                    Command="{Binding IncreaseParticipantsCommand}"
                                    HeightRequest="36"
                                    WidthRequest="36" />
                                <Label Text="{Binding ParticipantsCount}"
                                       TextColor="White"
                                       FontSize="10"
                                       HorizontalOptions="Center"/>
                            </StackLayout>

                            <!-- LIKES -->
                            <StackLayout Spacing="4">
                                <ImageButton
                                    Source="likes"
                                    Command="{Binding IncreaseLikesCommand}"
                                    HeightRequest="36"
                                    WidthRequest="36" />
                                <Label Text="{Binding LikesCount}"
                                       TextColor="White"
                                       FontSize="10"
                                       HorizontalOptions="Center"/>
                            </StackLayout>

                            <!-- SHARE -->
                            <StackLayout Spacing="4">
                                <ImageButton
                                    Source="share"
                                    Command="{Binding IncreaseShareCommand}"
                                    HeightRequest="36"
                                    WidthRequest="36" />
                                <Label Text="{Binding ShareCount}"
                                       TextColor="White"
                                       FontSize="10"
                                       HorizontalOptions="Center"/>
                            </StackLayout>

                            <!-- COMMENTS -->
                            <StackLayout Spacing="4">
                                <ImageButton
                                    Source="comments"
                                    Command="{Binding OpenCommentsCommand}"
                                    HeightRequest="36"
                                    WidthRequest="36" />
                                <Label Text="{Binding CommentCount}"
                                       TextColor="White"
                                       FontSize="10"
                                       HorizontalOptions="Center"/>
                            </StackLayout>

                        </StackLayout>

                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

        <BoxView
            Color="#80000000"
            IsVisible="{Binding Videos[0].IsCommentsVisible}"
            InputTransparent="False"
            />

        <!-- COMMENTS PANEL -->
        <Frame
            x:Name="CommentPanel"
            IsVisible="False"
            BackgroundColor="White"
            CornerRadius="20"
            Padding="20"
            TranslationY="500"
            VerticalOptions="End"
            HeightRequest="450"
            HasShadow="True"
            BindingContext="{Binding SelectedVideo}">

            <Grid RowDefinitions="Auto,*">

                <!-- CLOSE BUTTON -->
                <ImageButton
        Grid.Row="0"
        Source="close"
        Command="{Binding Source={x:Reference Reels}, Path=BindingContext.SelectedVideo.CloseCommentsCommand}"
        HorizontalOptions="End"
        HeightRequest="30"
        WidthRequest="30"/>

                <!-- COMMENTS CONTENT -->
                <VerticalStackLayout 
        Grid.Row="1"
        Spacing="10">

                    <Label Text="Comments"
               FontSize="18"
               TextColor="Black"
               FontAttributes="Bold" />

                    <CollectionView ItemsSource="{Binding Comments}">
                        <CollectionView.EmptyView>
                            <Label Text="No comments yet."
                       TextColor="Gray"
                       FontSize="14" />
                        </CollectionView.EmptyView>

                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Label Text="{Binding .}"
                           FontSize="14"
                           TextColor="Black"/>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <Grid ColumnDefinitions="*,Auto">
                        <Entry 
                Text="{Binding Source={x:Reference Reels}, Path=BindingContext.SelectedVideo.NewComment}"
                Placeholder="Add a comment..."
                FontSize="18"
                TextColor="Black" />

                        <Button 
                Grid.Column="1"
                Text="Send"
                Command="{Binding Source={x:Reference Reels}, Path=BindingContext.SelectedVideo.SendCommentCommand}" />
                    </Grid>

                </VerticalStackLayout>

            </Grid>


        </Frame>

        <Grid
        BackgroundColor="#80000000"  
            IsVisible="{Binding IsLoading}">
            <ActivityIndicator
            IsRunning="{Binding IsLoading}"
            Color="White"
            HorizontalOptions="Center"
            VerticalOptions="Center"
            WidthRequest="60"
            HeightRequest="60"/>
        </Grid>
    </Grid>
</ContentPage>
    
    
    