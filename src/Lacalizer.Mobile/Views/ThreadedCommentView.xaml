<ContentView
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Lacalizer.Mobile.Views"
    x:Class="Lacalizer.Mobile.Views.ThreadedCommentView">

    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">

        <!-- INDENT COLUMN -->
        <BoxView
            Grid.RowSpan="2"
            Grid.Column="0"
            WidthRequest="{Binding Depth, Converter={StaticResource DepthToMarginConverter}}"
            Color="Transparent"/>

 
        <!-- COMMENT CONTENT -->
        <VerticalStackLayout Grid.Column="1" Spacing="4">

            <!-- AUTHOR + LIKES -->
            <Grid ColumnDefinitions="*,Auto">
                <Label
            Text="{Binding Author}"
            FontAttributes="Bold"
            TextColor="Black" />

                <!-- LIKES (right aligned) -->
                <StackLayout
            Grid.Column="1"
            Spacing="2"
            HorizontalOptions="End">

                    <ImageButton
                Source="likes"
                Command="{Binding IncreaseCommentLikesCommand}"
                HeightRequest="20"
                WidthRequest="20"
                BackgroundColor="Transparent"/>

                    <Label
                Text="{Binding CommentLikesCount}"
                FontSize="10"
                TextColor="Gray"
                HorizontalOptions="Center"/>
                </StackLayout>
            </Grid>

            <!-- COMMENT TEXT -->
            <Label
        Text="{Binding Content}"
        TextColor="Black" />

            <!-- TIME + REPLY -->
            <HorizontalStackLayout Spacing="12">
                <Label
            Text="{Binding CreatedAt,
                           Converter={StaticResource TimeAgoConverter}}"
            FontSize="11"
            TextColor="Gray"/>

                <Button
            Text="Reply"
            FontSize="12"
            Padding="0"
            BackgroundColor="Transparent"
            Command="{Binding Source={RelativeSource AncestorType={x:Type local:ThreadedCommentView}},
                              Path=ReplyCommand}"
            CommandParameter="{Binding .}" />
                
            </HorizontalStackLayout>

            <!-- INLINE REPLY -->
            <Grid IsVisible="{Binding IsReplying}"
          TranslationY="20"
          Opacity="0">

                <Grid.Triggers>
                    <DataTrigger TargetType="Grid"
                         Binding="{Binding IsReplying}"
                         Value="True">
                        <Setter Property="Opacity" Value="1"/>
                        <Setter Property="TranslationY" Value="0"/>
                    </DataTrigger>
                </Grid.Triggers>

                <Grid ColumnDefinitions="*,Auto">
                    <Entry
                Text="{Binding ReplyText}"
                Placeholder="Reply..."
                FontSize="14"
                TextColor="Black"/>

                    <ImageButton
    Grid.Column="1"
    Source="send"
    HeightRequest="22"
    WidthRequest="22"
    BackgroundColor="Transparent"
    Command="{Binding Source={RelativeSource AncestorType={x:Type local:ThreadedCommentView}},
                      Path=SendReplyCommand}"
    CommandParameter="{Binding .}" />

                </Grid>
            </Grid>

        </VerticalStackLayout>


        <!-- CHILDREN -->
        <VerticalStackLayout
            Grid.Row="1"
            Grid.Column="1"
            BindableLayout.ItemsSource="{Binding Children}"
            Spacing="6"
            Margin="0,6,0,0">

            <BindableLayout.ItemTemplate>
                <DataTemplate>
                    <local:ThreadedCommentView BindingContext="{Binding}" />
                </DataTemplate>
            </BindableLayout.ItemTemplate>

        </VerticalStackLayout>

    </Grid>
</ContentView>
