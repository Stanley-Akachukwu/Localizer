<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Lacalizer.Mobile"
             xmlns:conv="clr-namespace:Lacalizer.Mobile.Converters"
             x:Class="Lacalizer.Mobile.App">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <conv:DepthToMarginConverter x:Key="DepthToMarginConverter" />
            <conv:TimeAgoConverter x:Key="TimeAgoConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
