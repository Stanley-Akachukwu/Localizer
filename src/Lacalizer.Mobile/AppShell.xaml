<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="Lacalizer.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Lacalizer.Mobile.Views"
    xmlns:local="clr-namespace:Lacalizer.Mobile"
    Title="Lacalizer.Mobile"
     Shell.FlyoutBehavior="Disabled">

    <TabBar>
        <Tab Title="Home"
         Icon="{FontImage FontFamily='MaterialIcons-Regular',
                        Glyph='&#xe88a;'}">
            <ShellContent ContentTemplate="{DataTemplate views:MainPage}"
                      Route="MainPage" />
        </Tab>

        <Tab Title="Localizer"
         Icon="{FontImage FontFamily='MaterialIcons-Regular',
                        Glyph='&#xe3b3;'}">
            <ShellContent ContentTemplate="{DataTemplate views:ReelPage}"
                      Route="Reel" />
        </Tab>
    </TabBar>


</Shell>
